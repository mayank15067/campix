<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%-include("adminnavbar.ejs")%>
    <div class="container my-5">

        <h2 class="text-center mb-5 fw-bold text-primary">
    <i class="fa-solid fa-calendar-days me-2"></i>All Events
  </h2>

  <div class="row g-4">

    <% for (event of events) { %>

      <div class="col-md-6">

        <div class="card shadow-sm border rounded-3 h-100">
          <div class="card-body d-flex flex-column">

            <!-- Title -->
            <h5 class="fw-bold text-primary mb-1">
              <%= event.title %>
            </h5>

            <!-- Organizer -->
            <p class="text-muted small mb-2">
              Organized by <strong><%= event.organized %></strong>
            </p>

            <!-- Description -->
            <h6 class="text-secondary small mb-3">
              <%= event.description %>
            </h6>

            <hr>

            <!-- Event Details -->
            <p class="mb-1">
              📍 <strong>Venue:</strong> <%= event.venue %>
            </p>

            <p class="mb-1">
              📅 <strong>Date:</strong> <%= event.date %>
            </p>

            <p class="mb-2">
              ⏰ <strong>Time:</strong> <%= event.time %>
            </p>

            <!-- Contact -->
            <p class="small text-muted mb-3">
              👤 <strong>Event Head:</strong> <%= event.headname %><br>
              📞 <strong>Contact:</strong> <%= event.contact %>
            </p>



          </div>
        </div>

      </div>

    <% } %>

  </div>

</div>

    <%- include("footer.ejs") %>
    
</body>
</html>