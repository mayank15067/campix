<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
        <style>
.card-hover {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card-hover:hover {
  transform: translateY(-5px);
  box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
}
</style>
</head>
<body>
    <%-include("navbar.ejs")%>
<div class="container my-5">

  <h2 class="text-center mb-5 fw-bold text-danger">
    <i class="fa-solid fa-triangle-exclamation me-2"></i>All Complaints
  </h2>

  <div class="row g-4">

    <% for(complain of complaints) { %>

      <div class="col-lg-6 card shadow-sm border rounded-3 card-hover">

        <div class="card shadow-sm border-0 rounded-4 h-100">

          <div class="card-body d-flex">

            <!-- Upvote Section -->
            <div class="text-center me-3">

  <button 
    class="btn btn-light border mb-2 like-btn" 
    data-id="<%= complain._id %>"
  >
    <i class="fa-regular fa-thumbs-up"></i>
  </button>

  <div class="fw-bold text-primary">
    <%= complain.votes %>
  </div>

</div>
            <!-- Content -->
            <div class="flex-grow-1">

              <!-- Title -->
              <h5 class="fw-bold mb-1">
                <%= complain.title %>
              </h5>

              <!-- Status Badge -->
              <span class="badge 
                <%= complain.status === 'Rsolved' ? 'bg-success' : 
                complain.status === 'Rejected' ? 'bg-danger' : 
                complain.status === 'under review' ? 'bg-info' : 
                    complain.status === 'In Progress' ? 'bg-warning text-dark' : 
                    'bg-secondary' %> mb-2">
                <%= complain.status %>
              </span>

              <!-- Description -->
              <p class="text-secondary small mb-3">
                <%= complain.description %>
              </p>

              <!-- Info -->
              <p class="small text-muted mb-1">
                <i class="fa-solid fa-user me-1"></i>
                <%= complain.firstname %> <%= complain.lastname %>
              </p>

              <p class="small text-muted mb-1">
                <i class="fa-solid fa-id-card me-1"></i>
                <%= complain.enrollment %>
              </p>

              <p class="small text-muted">
                <i class="fa-solid fa-graduation-cap me-1"></i>
                Year <%= complain.year %>, Sem <%= complain.sem %>
              </p>

            </div>

          </div>

        </div>

      </div>

    <% } %>

  </div>

</div>

    <%- include("footer.ejs") %>
    <script>  
      // Toggle icon

document.querySelectorAll(".like-btn").forEach(btn => {
  btn.addEventListener("click", async function () {

    const icon = this.querySelector("i");
    const id = this.dataset.id;
    const voteDisplay = this.nextElementSibling;

    let url;

    if (icon.classList.contains("fa-regular")) {
      icon.classList.remove("fa-regular");
      icon.classList.add("fa-solid");
      url = `/allcomplaints/upvote/${id}`;
    } else {
      icon.classList.remove("fa-solid");
      icon.classList.add("fa-regular");
      url = `/allcomplaints/downvote/${id}`;
    }

    // Call backend
    const res = await fetch(url);
    const data = await res.json();

    // Update votes instantly
    voteDisplay.innerText = data.votes;

  });
});
</script>
    
</body>
</html>