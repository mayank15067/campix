<body>
    <!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="d-flex flex-column min-vh-100">

  <%- include("adminnavbar.ejs") %>

  <!-- HEADER -->
  <div class="container text-center my-5">
    <h2 class="fw-bold text-primary">
      <i class="fa-solid fa-user-shield me-2"></i>Admin Dashboard
    </h2>
    <p class="text-muted">
      Manage complaints, monitor events, and keep the campus system running smoothly.
    </p>
  </div>

  <!-- QUICK ACTIONS -->
  <div class="container my-5">
    <div class="row g-4 text-center">

      <div class="col-md-6">
        <div class="card shadow-sm border rounded-3 h-100">
          <div class="card-body">
            <i class="fa-solid fa-triangle-exclamation fs-2 text-danger mb-3"></i>
            <h5 class="fw-semibold">Manage Complaints</h5>
            <p class="text-muted small">Review, update status, and resolve student issues.</p>
            <a href="/admin/complaints" class="btn btn-outline-danger btn-sm">
              View Complaints
            </a>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card shadow-sm border rounded-3 h-100">
          <div class="card-body">
            <i class="fa-solid fa-calendar-days fs-2 text-success mb-3"></i>
            <h5 class="fw-semibold">Manage Events</h5>
            <p class="text-muted small">View and monitor all campus events.</p>
            <a href="/admin/events" class="btn btn-outline-success btn-sm">
              View Events
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- STATS -->
  <div class="container my-5">
    <div class="row text-center g-4">

      <div class="col-md-4">
        <div class="p-3 border rounded-3 shadow-sm">
          <h4 class="fw-bold text-danger">120+</h4>
          <p class="small text-muted mb-0">Total Complaints</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="p-3 border rounded-3 shadow-sm">
          <h4 class="fw-bold text-success">80+</h4>
          <p class="small text-muted mb-0">Total Events</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="p-3 border rounded-3 shadow-sm">
          <h4 class="fw-bold text-primary">95%</h4>
          <p class="small text-muted mb-0">Resolution Rate</p>
        </div>
      </div>

    </div>
  </div>

  <%- include("footer.ejs") %>

</body>
</html>
</body>
</html>