<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Campix</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <!-- Hover Effect -->
  <style>
    .card-hover {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .card-hover:hover {
      transform: translateY(-5px);
      box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
    }
  </style>
</head>

<body class="d-flex flex-column min-vh-100">

  <%- include("navbar.ejs") %>

  <!-- HERO -->
  <div class="container text-center my-5">
    <h1 class="fw-bold text-primary">Welcome to Campix 🎓</h1>
    <p class="text-muted">Your smart college platform for complaints & events</p>

    <div class="mt-4">
      <a href="/newcomplaints" class="btn btn-danger me-2 px-4">
        <i class="fa-solid fa-pen me-1"></i>Raise Complaint
      </a>
      <a href="/newevent" class="btn btn-success px-4">
        <i class="fa-solid fa-calendar-plus me-1"></i>Create Event
      </a>
    </div>
  </div>

  <!-- QUICK ACTIONS -->
  <div class="container my-5">
    <div class="row g-4 text-center">

      <div class="col-md-4">
        <div class="card shadow-sm border rounded-3 h-100 card-hover">
          <div class="card-body">
            <i class="fa-solid fa-triangle-exclamation fs-2 text-danger mb-3"></i>
            <h5 class="fw-semibold">Complaints</h5>
            <p class="text-muted small">Report and track campus issues</p>
            <a href="/allcomplaints" class="btn btn-outline-danger btn-sm">View</a>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow-sm border rounded-3 h-100 card-hover">
          <div class="card-body">
            <i class="fa-solid fa-calendar-days fs-2 text-success mb-3"></i>
            <h5 class="fw-semibold">Events</h5>
            <p class="text-muted small">Explore and join campus events</p>
            <a href="/allevents" class="btn btn-outline-success btn-sm">View</a>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow-sm border rounded-3 h-100 card-hover">
          <div class="card-body">
            <i class="fa-solid fa-chart-line fs-2 text-primary mb-3"></i>
            <h5 class="fw-semibold">Dashboard</h5>
            <p class="text-muted small">Track your activity & stats</p>
            <a href="#" class="btn btn-outline-primary btn-sm">Open</a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- FEATURES -->
  <div class="container my-5">
    <h3 class="text-center fw-bold mb-4">Why Campix?</h3>

    <div class="row g-4 text-center">

      <div class="col-md-3">
        <div class="p-3 border rounded-3 shadow-sm card-hover">
          <i class="fa-solid fa-bolt text-warning fs-4 mb-2"></i>
          <p class="small mb-0">Fast Resolution</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="p-3 border rounded-3 shadow-sm card-hover">
          <i class="fa-solid fa-users text-primary fs-4 mb-2"></i>
          <p class="small mb-0">Student Collaboration</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="p-3 border rounded-3 shadow-sm card-hover">
          <i class="fa-solid fa-bell text-danger fs-4 mb-2"></i>
          <p class="small mb-0">Real-time Updates</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="p-3 border rounded-3 shadow-sm card-hover">
          <i class="fa-solid fa-lock text-success fs-4 mb-2"></i>
          <p class="small mb-0">Secure Platform</p>
        </div>
      </div>

    </div>
  </div>

  <!-- STATS -->
  <div class="container my-5">
    <div class="row text-center g-4">

      <div class="col-md-3">
        <div class="p-3 border rounded-3 shadow-sm card-hover">
          <h4 class="fw-bold text-primary">120+</h4>
          <p class="small text-muted mb-0">Complaints</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="p-3 border rounded-3 shadow-sm card-hover">
          <h4 class="fw-bold text-success">80+</h4>
          <p class="small text-muted mb-0">Events</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="p-3 border rounded-3 shadow-sm card-hover">
          <h4 class="fw-bold text-danger">95%</h4>
          <p class="small text-muted mb-0">Resolved</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="p-3 border rounded-3 shadow-sm card-hover">
          <h4 class="fw-bold text-warning">500+</h4>
          <p class="small text-muted mb-0">Students</p>
        </div>
      </div>

    </div>
  </div>

  <%- include("footer.ejs") %>

</body>
</html>
</body>
</html>